/* ===== Flomi Journal 记录页 ===== */

.page {
  width: 100%;
  min-height: 100vh;
  background: var(--color-background);
  position: relative;
  display: flex;
  flex-direction: column;
  padding-bottom: 80rpx;
}

.ambient-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
.orb { position: absolute; border-radius: 9999rpx; filter: blur(160rpx); }
.orb--a { top: -200rpx; right: -100rpx; width: 600rpx; height: 600rpx; background: rgba(218, 232, 190, 0.3); }
.orb--b { bottom: -200rpx; left: -100rpx; width: 700rpx; height: 700rpx; background: rgba(250, 200, 200, 0.2); }

/* 导航栏 */
.nav-bar {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 96rpx 40rpx 24rpx;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-surface-container);
  border-radius: 9999rpx;
}

.back-icon { font-size: 36rpx; color: var(--color-on-surface); }

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-on-surface);
  letter-spacing: -0.01em;
}

.save-btn {
  padding: 16rpx 40rpx;
  background: var(--color-surface-container);
  border-radius: 9999rpx;
  transition: background 0.3s, transform 0.2s;
}

.save-btn--active {
  background: var(--color-primary-container);
}

.save-btn:active { transform: scale(0.95); }

.save-btn__text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-on-surface-variant);
}

.save-btn--active .save-btn__text {
  color: var(--color-on-primary-container);
}

/* 日期 + 情绪标签 */
.meta-row {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 48rpx;
}

.meta-date {
  font-size: 26rpx;
  color: var(--color-outline);
  font-weight: 400;
}

.emotion-tag {
  padding: 8rpx 24rpx;
  border-radius: 9999rpx;
  border: 1rpx solid transparent;
}

.emotion-tag__text {
  font-size: 24rpx;
  font-weight: 600;
}

/* 提示卡 */
.prompt-card {
  position: relative;
  z-index: 10;
  margin: 16rpx 48rpx 32rpx;
  background: linear-gradient(135deg, rgba(218, 232, 190, 0.45), rgba(203, 218, 176, 0.25));
  border-radius: 32rpx;
  padding: 32rpx 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.prompt-label {
  display: block;
  font-size: 20rpx;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-primary);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.prompt-text {
  display: block;
  font-size: 28rpx;
  color: var(--color-on-surface);
  font-weight: 400;
  line-height: 1.6;
  font-style: italic;
}

/* 输入区 */
.input-wrap {
  position: relative;
  z-index: 10;
  flex: 1;
  padding: 0 48rpx;
}

.journal-input {
  width: 100%;
  min-height: 400rpx;
  font-size: 32rpx;
  color: var(--color-on-surface);
  line-height: 1.9;
  font-weight: 300;
  background: transparent;
  border: none;
  padding: 0;
}

.journal-placeholder {
  color: var(--color-outline-variant);
  font-weight: 300;
  font-style: italic;
}

.char-count {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.char-count__text {
  font-size: 22rpx;
  color: var(--color-outline-variant);
}

/* 保存提示 */
.saved-toast {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%) translateY(40rpx);
  background: var(--color-on-surface);
  border-radius: 9999rpx;
  padding: 20rpx 48rpx;
  opacity: 0;
  transition: opacity 0.3s, transform 0.3s;
  pointer-events: none;
  z-index: 200;
}

.saved-toast--visible {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

.saved-toast__text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}
