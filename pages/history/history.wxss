/* 历史记录页 */

/* 导航栏标题（fixed，与胶囊同行） */
.history-nav-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.history-nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #31332f;
  letter-spacing: -0.01em;
}

.page-bg {
  min-height: 100vh;
  background: #f5f5f0;
  display: flex;
  flex-direction: column;
}

/* ── 周视图 ── */
.week-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx 16rpx;
}

.week-day {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  margin: 0 6rpx;
  border-radius: 999rpx;
  transition: background 0.2s;
}

.week-day--active {
  background: rgba(218, 232, 190, 0.7);
  border-radius: 999rpx;
}

/* 过去日期：文字整体更淡 */
.week-day--past .week-day__label {
  color: #ccc;
}

.week-day--past .week-day__num {
  color: #ccc;
}

.week-day__label {
  font-size: 22rpx;
  color: #999;
  font-weight: 400;
}

.week-day--active .week-day__label {
  color: #576342;
  font-weight: 600;
}

.week-day__num {
  font-size: 32rpx;
  color: #3a3a3a;
  font-weight: 500;
  line-height: 1;
}

.week-day--active .week-day__num {
  color: #576342;
  font-weight: 700;
}

.week-day__dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: transparent;
}

.week-day__dot--show {
  background: rgba(140, 148, 200, 0.6);
}

.week-day--active .week-day__dot--show {
  background: #576342;
}

/* ── 内容滚动区 ── */
.content-scroll {
  flex: 1;
  position: relative;
  padding: 24rpx 24rpx 120rpx;
  box-sizing: border-box;
  transition: opacity 0.2s ease;
}

.content-scroll--switching {
  opacity: 0;
}

/* ── 空状态 ── */
.empty-wrap {
  position: absolute;
  left: 0;
  right: 0;
  top: calc(50% - 20rpx);
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.empty-icon {
  font-size: 72rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #aaa;
}

.analysis-summary {
  font-size: 26rpx;
  font-weight: 400;
  color: rgba(49, 51, 47, 0.38);
  line-height: 1.8;
  display: block;
  margin-bottom: 20rpx;
}

/* ── 行动推荐卡片 ── */
.action-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  background: rgba(255,255,255,0.55);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 24rpx 24rpx;
  margin-bottom: 20rpx;
  transition: opacity 0.1s, transform 0.1s;
}

.action-card--game {
  background: rgba(255,255,255,0.55);
}

.action-card--pressed {
  opacity: 0.6;
  transform: scale(0.98);
}

/* 方块图标（复用首页面板样式） */
.action-card__icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(184,192,255,0.5);
}

.action-card__icon-wrap--breath { background: rgba(184,192,255,0.5); }
.action-card__icon-wrap--bubble { background: rgba(218,232,190,0.6); }
.action-card__icon-wrap--doodle { background: rgba(255,218,150,0.5); }
.action-card__icon-wrap--text   { background: rgba(179,214,240,0.55); }

/* text 类型 emoji 字号 */
.action-card__icon-text {
  font-size: 36rpx;
  line-height: 1;
}

/* 文字符号图标（与首页面板一致） */
.action-card__icon-symbol {
  font-size: 40rpx;
  line-height: 1;
}
.action-card__icon-symbol--breath { color: #5C6BC0; }
.action-card__icon-symbol--bubble { font-size: 46rpx; color: #6A8F3D; }
.action-card__icon-symbol--doodle { color: #B07D2A; }

.action-card__text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.action-card__label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-on-surface);
}

.action-card__desc {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.5;
}

/* ── 折线图卡片 ── */
.chart-card {
  background: rgba(255,255,255,0.55);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 28rpx 24rpx 28rpx;
  margin-bottom: 20rpx;
}

.chart-date-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.chart-date-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #3a3a3a;
}

.chart-count {
  font-size: 24rpx;
  color: #aaa;
}

.chart-canvas {
  width: 100%;
  height: 400rpx;
  display: block;
  border-radius: 12rpx;
}

.chart-canvas--hidden {
  height: 0;
  overflow: hidden;
}

/* chart-wrap：相对定位容器，气泡绝对定位在其内 */
.chart-wrap {
  position: relative;
  width: 100%;
  display: block;
}

.chart-placeholder {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
}

/* ── 折线图气泡 ── */
.chart-tooltip {
  position: absolute;
  transform: translateX(-50%);
  background: rgba(30,30,28,0.82);
  border-radius: 12rpx;
  padding: 8rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  pointer-events: none;
  white-space: nowrap;
}

.chart-tooltip__label {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  line-height: 1.4;
}

.chart-tooltip__time {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  line-height: 1.3;
}

