/* 历史记录页 */
.page-bg {
  min-height: 100vh;
  background: #f5f5f0;
  display: flex;
  flex-direction: column;
}

/* ── 周视图 ── */
.week-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx 16rpx;
}

.week-day {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  margin: 0 6rpx;
  border-radius: 999rpx;
  transition: background 0.2s;
}

.week-day--active {
  background: rgba(218, 232, 190, 0.7);
  border-radius: 999rpx;
  margin: 0 9rpx;
}

.week-day__label {
  font-size: 22rpx;
  color: #999;
  font-weight: 400;
}

.week-day--active .week-day__label {
  color: #576342;
  font-weight: 600;
}

.week-day__num {
  font-size: 32rpx;
  color: #3a3a3a;
  font-weight: 500;
  line-height: 1;
}

.week-day--active .week-day__num {
  color: #576342;
  font-weight: 700;
}

.week-day__dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: transparent;
}

.week-day__dot--show {
  background: rgba(140, 148, 200, 0.6);
}

.week-day--active .week-day__dot--show {
  background: #576342;
}

/* ── 内容滚动区 ── */
.content-scroll {
  flex: 1;
  padding: 24rpx 24rpx 120rpx;
  box-sizing: border-box;
  transition: opacity 0.2s ease;
}

.content-scroll--switching {
  opacity: 0;
}

/* ── 空状态 ── */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  gap: 20rpx;
}

.empty-icon {
  font-size: 72rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #aaa;
}

/* ── 心情分析卡片 ── */
.analysis-card {
  background: rgba(255,255,255,0.55);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 32rpx 28rpx 28rpx;
  margin-bottom: 20rpx;
}

.analysis-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.analysis-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3a3a3a;
}

.analysis-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.analysis-summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  display: block;
}

/* ── 折线图卡片 ── */
.chart-card {
  background: rgba(255,255,255,0.55);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 28rpx 24rpx 44rpx;
  margin-bottom: 20rpx;
}

.chart-date-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.chart-date-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #3a3a3a;
}

.chart-count {
  font-size: 24rpx;
  color: #aaa;
}

.chart-canvas {
  width: 100%;
  height: 320rpx;
  display: block;
  border-radius: 12rpx;
}

.chart-canvas--hidden {
  height: 0;
  overflow: hidden;
}

.chart-placeholder {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
}

/* ── 图例 ── */
.chart-legend {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 12rpx 40rpx;
  margin-top: 16rpx;
  padding: 0 4rpx;
}

.legend-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.legend-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.legend-label {
  font-size: 22rpx;
  line-height: 1;
  color: #888 !important;
}

