/* ===== Flomi Relief Page ===== */

.page-container {
  width: 100%;
  height: 100vh;
  background-color: var(--color-background);
  position: relative;
  overflow: hidden;
}

/* ---- Ambient Background ---- */
.ambient-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

.ambient-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(184, 192, 255, 0.25) 0%,
    rgba(251, 249, 245, 1) 50%,
    rgba(255, 218, 217, 0.25) 100%
  );
}

.ambient-orb {
  position: absolute;
  border-radius: 9999rpx;
  filter: blur(160rpx);
}

.ambient-orb--tl {
  top: -150rpx;
  left: -100rpx;
  width: 700rpx;
  height: 700rpx;
  background: rgba(83, 91, 147, 0.12);
}

.ambient-orb--br {
  bottom: -150rpx;
  right: -100rpx;
  width: 800rpx;
  height: 800rpx;
  background: rgba(87, 99, 66, 0.07);
}

/* ---- Header ---- */
.header {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  padding: 100rpx 48rpx 32rpx;
  background: rgba(251, 249, 245, 0.6);
  backdrop-filter: blur(40rpx);
}

.logo-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.logo-icon {
  font-size: 44rpx;
  color: #A3B18A;
}

.logo-text {
  font-size: 48rpx;
  font-weight: 600;
  color: #A3B18A;
  letter-spacing: -0.02em;
}

/* ---- Hero Text ---- */
.hero-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 5;
  text-align: center;
  pointer-events: none;
  width: 600rpx;
}

.hero-title {
  display: block;
  font-size: 64rpx;
  font-weight: 500;
  color: var(--color-on-surface);
  letter-spacing: -0.03em;
  opacity: 0.8;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--color-on-surface-variant);
  font-weight: 400;
  line-height: 1.5;
}

/* ---- Bubble Canvas ---- */
.bubble-canvas {
  position: absolute;
  inset: 0;
  z-index: 20;
}

/* ---- Individual Bubble ---- */
.bubble {
  position: absolute;
  border-radius: 9999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.06),
    inset 0 2rpx 8rpx rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(12rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  /* Floating animation */
  animation: bubbleFloat linear infinite alternate;
  transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  will-change: transform;
}

.bubble:active {
  transform: scale(0.92);
}

/* Shimmer layer inside bubble */
.bubble-shimmer {
  position: absolute;
  inset: 0;
  border-radius: 9999rpx;
  background: radial-gradient(
    ellipse at 30% 25%,
    rgba(255, 255, 255, 0.45) 0%,
    transparent 60%
  );
  pointer-events: none;
}

/* Highlight dot */
.bubble-highlight {
  position: absolute;
  top: 18%;
  left: 22%;
  width: 18%;
  height: 12%;
  border-radius: 9999rpx;
  background: rgba(255, 255, 255, 0.7);
  filter: blur(4rpx);
  pointer-events: none;
}

/* Popped state */
.bubble--popped {
  animation: bubblePop 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards !important;
  pointer-events: none;
}

/* Ripple state (brief flash before pop) */
.bubble--ripple {
  animation: bubbleRipple 0.15s ease-out forwards !important;
}

/* ---- Keyframes ---- */
@keyframes bubbleFloat {
  0% {
    transform: translateY(0rpx) rotate(0deg);
  }
  100% {
    transform: translateY(-30rpx) rotate(3deg);
  }
}

@keyframes bubblePop {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  30% {
    transform: scale(1.25);
    opacity: 0.8;
  }
  60% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  100% {
    transform: scale(0);
    opacity: 0;
  }
}

@keyframes bubbleRipple {
  0% { transform: scale(1); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); }
}

/* ---- Pop Counter ---- */
.pop-counter {
  position: absolute;
  top: 220rpx;
  right: 48rpx;
  z-index: 30;
  background: rgba(227, 227, 220, 0.5);
  backdrop-filter: blur(20rpx);
  border-radius: 9999rpx;
  padding: 12rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.pop-counter__text {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  font-weight: 500;
  letter-spacing: 0.05em;
}

/* ---- Done Button ---- */
.done-wrap {
  position: absolute;
  bottom: 180rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 30;
}

.done-btn {
  padding: 32rpx 96rpx;
  background: var(--color-on-surface);
  border-radius: 9999rpx;
  box-shadow: 0 40rpx 80rpx rgba(49, 51, 47, 0.15);
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.done-btn:active {
  transform: scale(0.96);
}

.done-btn--glow {
  background: var(--color-primary);
  box-shadow:
    0 40rpx 80rpx rgba(87, 99, 66, 0.3),
    0 0 0 8rpx rgba(218, 232, 190, 0.4);
}

.done-btn__text {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-surface);
  letter-spacing: 0.02em;
}

/* ---- Celebration Overlay ---- */
.celebration {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(49, 51, 47, 0.4);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s ease;
}

.celebration--visible {
  opacity: 1;
  pointer-events: auto;
}

.celebration-card {
  background: var(--color-surface-container-low);
  border-radius: 48rpx;
  padding: 80rpx 64rpx;
  width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 60rpx 120rpx rgba(49, 51, 47, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  animation: cardSlideUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

@keyframes cardSlideUp {
  from {
    transform: translateY(60rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.celebration-emoji {
  font-size: 96rpx;
}

.celebration-title {
  font-size: 56rpx;
  font-weight: 600;
  color: var(--color-on-surface);
  letter-spacing: -0.02em;
}

.celebration-body {
  font-size: 28rpx;
  color: var(--color-on-surface-variant);
  text-align: center;
  line-height: 1.6;
  font-weight: 300;
}

.celebration-btn {
  margin-top: 16rpx;
  padding: 28rpx 80rpx;
  background: var(--color-primary-container);
  border-radius: 9999rpx;
  transition: transform 0.2s;
}

.celebration-btn:active {
  transform: scale(0.96);
}

.celebration-btn__text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-on-primary-container);
}
