/* ===== Flomi 首页 ===== */

.page {
  width: 100%;
  height: 100vh;
  background: var(--color-background);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ---- 环境背景 ---- */
.ambient-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

.orb {
  position: absolute;
  border-radius: 9999rpx;
  filter: blur(120rpx);
  transition: background 1.8s ease;
  will-change: transform;
}

.orb--a {
  top: -180rpx;
  right: -120rpx;
  width: 680rpx;
  height: 680rpx;
  opacity: 0.4;
  animation: orbDrift1 14s ease-in-out infinite alternate;
}

.orb--b {
  bottom: -180rpx;
  left: -120rpx;
  width: 580rpx;
  height: 580rpx;
  background: rgba(218, 232, 190, 0.45);
  animation: orbDrift2 18s ease-in-out infinite alternate;
}

.orb--c {
  top: 40%;
  left: -200rpx;
  width: 500rpx;
  height: 500rpx;
  opacity: 0.28;
  animation: orbDrift3 22s ease-in-out infinite alternate;
}

.orb--d {
  top: 20%;
  right: -180rpx;
  width: 460rpx;
  height: 460rpx;
  background: rgba(252, 205, 195, 0.3);
  animation: orbDrift4 16s ease-in-out infinite alternate;
}

.orb--e {
  bottom: 25%;
  right: 10%;
  width: 360rpx;
  height: 360rpx;
  opacity: 0.22;
  animation: orbDrift5 20s ease-in-out infinite alternate;
}

@keyframes orbDrift1 {
  0%   { transform: translate(0, 0) scale(1); }
  50%  { transform: translate(-60rpx, 80rpx) scale(1.08); }
  100% { transform: translate(40rpx, -60rpx) scale(0.95); }
}

@keyframes orbDrift2 {
  0%   { transform: translate(0, 0) scale(1); }
  40%  { transform: translate(80rpx, -100rpx) scale(1.1); }
  100% { transform: translate(-40rpx, 60rpx) scale(0.92); }
}

@keyframes orbDrift3 {
  0%   { transform: translate(0, 0) scale(1); }
  60%  { transform: translate(100rpx, -80rpx) scale(1.12); }
  100% { transform: translate(50rpx, 100rpx) scale(0.9); }
}

@keyframes orbDrift4 {
  0%   { transform: translate(0, 0) scale(1); }
  45%  { transform: translate(-80rpx, 60rpx) scale(1.06); }
  100% { transform: translate(60rpx, -80rpx) scale(0.96); }
}

@keyframes orbDrift5 {
  0%   { transform: translate(0, 0) scale(1); }
  55%  { transform: translate(-100rpx, -60rpx) scale(1.15); }
  100% { transform: translate(80rpx, 80rpx) scale(0.88); }
}

/* ---- 顶部问候 ---- */
.greeting-bar {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  padding: 96rpx 48rpx 32rpx;
  transition: opacity 0.3s ease;
}

.greeting-bar--hidden {
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.greeting-inner {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.greeting-time {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  font-weight: 400;
  letter-spacing: 0.02em;
}

.greeting-question {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-on-surface);
  letter-spacing: -0.03em;
  line-height: 1.2;
}


/* ---- 气泡舞台 ---- */
.bubble-stage {
  position: relative;
  z-index: 10;
  flex: 1;
  overflow: hidden;
}

.stage-hint {
  position: absolute;
  bottom: 24rpx;
  left: 0;
  right: 0;
  z-index: 5;
  display: flex;
  justify-content: center;
}

.stage-hint__text {
  font-size: 24rpx;
  color: var(--color-outline);
  letter-spacing: 0.05em;
}


/* ---- 气泡场 ---- */
.bubble-field {
  position: absolute;
  inset: 0;
}

/* ---- 气泡基础样式 ---- */
.bubble {
  position: absolute;
  border-radius: 9999rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  overflow: hidden;
  animation: floatBubble ease-in-out infinite alternate;
  transition: transform 0.18s ease;
  will-change: transform, opacity;
  animation-fill-mode: both;
  /* 磨砂白色气泡：半透明近白底色，覆盖情绪色 */
  background: rgba(255,255,252,0.30) !important;
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border: 1.5rpx solid rgba(255,255,255,0.9);
  box-shadow:
    0 2rpx 16rpx rgba(0,0,0,0.04),
    0 0rpx 1rpx rgba(255,255,255,0.6);
}

.bubble:active {
  transform: scale(0.92) !important;
}

/* 情绪选择气泡 */
.bubble--emotion {
  box-shadow:
    0 4rpx 24rpx rgba(0,0,0,0.05),
    0 0rpx 1rpx rgba(255,255,255,0.7);
}

/* 关联词气泡 */
.bubble--word {
  box-shadow:
    0 2rpx 16rpx rgba(0,0,0,0.04),
    0 0rpx 1rpx rgba(255,255,255,0.6);
}

/* 消失动画 */
.bubble--popping {
  animation: bubblePop 0.38s cubic-bezier(0.22, 1, 0.36, 1) forwards !important;
}

.bubble--gone {
  display: none;
}

/* 内凹磨砂感：中心稍暗、边缘稍亮 */
.bubble-shimmer {
  position: absolute;
  inset: 0;
  border-radius: 9999rpx;
  pointer-events: none;
  background: radial-gradient(
    circle at 50% 50%,
    rgba(200,200,195,0.10) 0%,
    rgba(255,255,252,0.0) 55%,
    rgba(255,255,255,0.18) 100%
  );
}

/* emoji */
.bubble-emoji {
  line-height: 1;
  z-index: 1;
  text-align: center;
}

/* 情绪标签文字 */
.bubble-label {
  font-weight: 600;
  letter-spacing: 0.02em;
  text-align: center;
  z-index: 1;
}

/* 关联词文字 */
.bubble-word-text {
  font-weight: 500;
  letter-spacing: 0.02em;
  text-align: center;
  z-index: 1;
  padding: 0 12rpx;
}

/* 重复点击计数 */
.bubble-count {
  position: absolute;
  bottom: 14%;
  right: 14%;
  font-size: 20rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.9);
  background: rgba(0,0,0,0.18);
  border-radius: 9999rpx;
  padding: 2rpx 10rpx;
  z-index: 2;
}

/* ---- Combo 计数器 ---- */
.combo-wrap {
  position: fixed;
  /* 紧贴 TabBar 顶部：TabBar 内容高约 100rpx，再留 44rpx 间距（上移 24rpx） */
  bottom: calc(100rpx + env(safe-area-inset-bottom) + 44rpx);
  left: 50%;
  transform: translateX(-50%) translateY(20rpx);
  z-index: 110; /* 高于 TabBar(100)，确保不被遮挡 */
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.combo-wrap--visible {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

.combo-inner {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 10rpx;
  background: rgba(49, 51, 47, 0.28);
  backdrop-filter: blur(16rpx);
  border-radius: 9999rpx;
  padding: 14rpx 36rpx;
}

/* 每次数字变化时触发弹跳 */
.combo-inner--pop {
  animation: comboPop 0.3s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

@keyframes comboPop {
  0%   { transform: scale(1); }
  45%  { transform: scale(1.18); }
  100% { transform: scale(1); }
}

.combo-num {
  font-size: 48rpx;
  font-weight: 600;
  color: rgba(49, 51, 47, 0.65);
  letter-spacing: -0.03em;
  line-height: 1;
}

.combo-label {
  font-size: 22rpx;
  font-weight: 500;
  color: rgba(49, 51, 47, 0.35);
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

/* ---- 底部操作区（底部抽屉，覆盖 TabBar） ---- */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 120;
  display: flex;
  flex-direction: column;
  gap: 36rpx;
  padding: 36rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  background: rgba(251, 249, 245, 0.92);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 40rpx 40rpx 0 0;
  box-shadow: 0 -8rpx 48rpx rgba(0, 0, 0, 0.08);
  transform: translateY(100%);
  transition: transform 0.48s cubic-bezier(0.22, 1, 0.36, 1);
  pointer-events: none;
}

.bottom-action--visible {
  transform: translateY(0);
  pointer-events: auto;
}

/* ---- 游戏选项卡（内联在首页底部面板） ---- */
.game-cards-inline {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.game-cards-inline__header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.game-cards-inline__header-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.game-cards-inline__main {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-on-surface);
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.game-cards-inline__sub {
  font-size: 26rpx;
  font-weight: 400;
  color: var(--color-on-surface-variant);
  letter-spacing: 0.01em;
  opacity: 0.7;
}

.game-card-inline {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border-radius: 28rpx;
  padding: 24rpx 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  transition: transform 0.2s;
}

.game-card-inline:active {
  transform: scale(0.97);
}

.game-card-inline__icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.game-card-inline__icon--breath { background: rgba(184, 192, 255, 0.5); }
.game-card-inline__icon--bubble { background: rgba(218, 232, 190, 0.6); }
.game-card-inline__icon--doodle { background: rgba(255, 218, 150, 0.5); }

.game-card-inline__icon-text {
  font-size: 36rpx;
  color: var(--color-on-surface);
}

.game-card-inline__body {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.game-card-inline__name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-on-surface);
  letter-spacing: -0.01em;
}

.game-card-inline__desc {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.4;
}

.game-card-inline__duration {
  font-size: 22rpx;
  color: var(--color-outline);
}

/* 内联提示卡 */
.inline-prompt-card {
  background: rgba(218, 232, 190, 0.45);
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.inline-prompt-label {
  font-size: 20rpx;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-primary);
  font-weight: 600;
}

.inline-prompt-text {
  font-size: 28rpx;
  color: var(--color-on-surface);
  line-height: 1.55;
  font-style: italic;
}

/* 正向面板小标题 */
.inline-panel-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

/* 关闭按钮（所有底部面板通用） */
.panel-close-btn {
  margin-left: auto;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: rgba(49, 51, 47, 0.65);
  flex-shrink: 0;
  transition: color 0.15s;
}

.panel-close-btn:active {
  background: transparent;
  color: rgba(49, 51, 47, 0.9);
}

.inline-panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-on-surface);
  letter-spacing: -0.01em;
}

.inline-panel-emotion {
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 18rpx;
  border-radius: 9999rpx;
}

/* 内联输入框 */
.inline-input-wrap {
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: column;
}

.inline-input {
  width: 100%;
  font-size: 28rpx;
  color: var(--color-on-surface);
  line-height: 1.7;
  font-weight: 300;
  background: transparent;
  min-height: 200rpx;
  max-height: 400rpx;
}

.inline-placeholder {
  color: var(--color-outline-variant);
  font-style: italic;
  font-weight: 300;
}

/* 负向舒缓提示 */
.inline-game-hint {
  padding: 8rpx 0;
}

.inline-game-hint__text {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  text-align: center;
}

/* 底部面板双按钮行 */
.panel-btn-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.panel-btn {
  flex: 1;
  padding: 28rpx 0;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s, opacity 0.2s;
}

.panel-btn:active {
  transform: scale(0.97);
}

.panel-btn--primary {
  background: rgba(87, 99, 66, 0.55);
}

.panel-btn--secondary {
  background: rgba(49, 51, 47, 0.08);
}

.panel-btn--disabled {
  opacity: 0.3;
  pointer-events: none;
}

.panel-btn__text {
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
  letter-spacing: 0.02em;
}

.panel-btn__text--secondary {
  color: var(--color-on-surface-variant);
}


/* ---- 关键帧 ---- */

/* 主浮动：XY 都有位移 + 轻微呼吸缩放 + 微旋转 */
@keyframes floatBubble {
  0%   { transform: translate(0, 0) rotate(-1.5deg) scale(1); }
  20%  { transform: translate(6rpx, -18rpx) rotate(1deg) scale(1.025); }
  45%  { transform: translate(-4rpx, -30rpx) rotate(-0.5deg) scale(0.975); }
  70%  { transform: translate(8rpx, -20rpx) rotate(2deg) scale(1.02); }
  100% { transform: translate(-2rpx, -38rpx) rotate(-1deg) scale(1.01); }
}

/* 副浮动：节奏错开，轨迹不同 */
@keyframes floatBubbleAlt {
  0%   { transform: translate(0, -10rpx) rotate(1deg) scale(1.01); }
  25%  { transform: translate(-8rpx, -28rpx) rotate(-1.5deg) scale(0.97); }
  55%  { transform: translate(5rpx, -14rpx) rotate(2.5deg) scale(1.03); }
  80%  { transform: translate(-6rpx, -32rpx) rotate(-0.5deg) scale(0.985); }
  100% { transform: translate(3rpx, 0) rotate(1deg) scale(1); }
}

/* 第三种浮动：更慢更大幅度，给大气泡用 */
@keyframes floatBubbleSlow {
  0%   { transform: translate(0, 0) rotate(0.5deg) scale(1); }
  30%  { transform: translate(-10rpx, -22rpx) rotate(-1deg) scale(1.03); }
  60%  { transform: translate(12rpx, -36rpx) rotate(1.5deg) scale(0.97); }
  100% { transform: translate(-5rpx, -16rpx) rotate(-0.5deg) scale(1.015); }
}

/* 点击弹出 */
@keyframes bubblePop {
  0%   { transform: scale(1);    opacity: 1; }
  30%  { transform: scale(1.28); opacity: 0.9; }
  55%  { transform: scale(0.6);  opacity: 0.5; }
  100% { transform: scale(0);    opacity: 0; }
}
