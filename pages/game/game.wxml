<!-- Flomi 解压小游戏 — 呼吸练习 + 清空烦恼 + 涂鸦 -->
<view class="page">

  <!-- 状态栏占位（自定义导航栏） -->
  <view style="height:{{statusBarHeight}}px;"></view>

  <!-- 导航栏：返回按钮 + 页面标题 -->
  <view class="game-nav-bar" style="top:{{menuBtnTop}}px;height:{{menuBtnHeight}}px;">
    <view class="game-back-btn" bindtap="goBack">
      <image class="game-back-icon" src="/assets/icons/back.svg" mode="aspectFit"></image>
    </view>
    <text class="game-nav-title">{{gameTitle}}</text>
  </view>

  <!-- 背景 -->
  <view class="ambient-bg">
    <view class="orb orb--a"></view>
    <view class="orb orb--b"></view>
  </view>

  <!-- 游戏一：呼吸放松 -->
  <view class="breath-game" wx:if="{{currentGame === 'breath'}}">

    <!-- 圆圈动画区 -->
    <view class="breath-circle-wrap">
      <view class="breath-ring breath-ring--outer {{breathStatus === 'running' ? breathPhase : ''}}"></view>
      <view class="breath-ring breath-ring--mid {{breathStatus === 'running' ? breathPhase : ''}}"></view>
      <view class="breath-circle {{breathStatus === 'running' ? breathPhase : ''}}">
        <!-- idle 状态：提示 + 开始按钮 -->
        <block wx:if="{{breathStatus === 'idle'}}">
          <text class="breath-start-text" bindtap="breathStart">开始</text>
        </block>
        <!-- running / paused：动作 + 秒数 -->
        <block wx:else>
          <text class="breath-action">{{breathInstruction}}</text>
          <text class="breath-count">{{breathCount}}</text>
          <text class="breath-count-unit">秒</text>
        </block>
      </view>
    </view>

    <!-- 轮次 + 进度条（始终占位，idle 时不可见） -->
    <text class="breath-round {{breathStatus === 'idle' ? 'breath-round--hidden' : ''}}">第 {{breathRound}} / {{breathTotalRounds}} 轮</text>
    <view class="breath-progress-wrap {{breathStatus === 'idle' ? 'breath-progress-wrap--hidden' : ''}}">
      <view class="breath-progress">
        <view class="breath-progress__bar" style="width:{{breathProgress}}%;background:{{breathBarColor}};"></view>
      </view>
    </view>

    <!-- 控制按钮组（始终占位，idle 时不可见） -->
    <view class="breath-controls {{breathStatus === 'idle' ? 'breath-controls--hidden' : ''}}">
      <!-- 结束 -->
      <view
        class="breath-ctrl-btn breath-ctrl-btn--ghost"
        bindtap="breathStop"
      >
        <text class="breath-ctrl-text breath-ctrl-text--ghost">结束</text>
      </view>
      <!-- 继续 / 暂停 -->
      <view
        class="breath-ctrl-btn {{breathStatus === 'paused' ? 'breath-ctrl-btn--primary' : 'breath-ctrl-btn--secondary'}}"
        bindtap="{{breathStatus === 'paused' ? 'breathStart' : 'breathPause'}}"
      >
        <text class="breath-ctrl-text {{breathStatus === 'paused' ? '' : 'breath-ctrl-text--secondary'}}">{{breathStatus === 'paused' ? '继续' : '暂停'}}</text>
      </view>
    </view>

  </view>

  <!-- 游戏二：清空烦恼 -->
  <view class="emoji-game" wx:if="{{currentGame === 'bubble'}}">
    <!-- combo 计数（顶部） -->
    <view class="bubble-combo-bar" wx:if="{{!showClearDone}}">
      <text class="bubble-combo-num">{{bubbleCombo}}</text>
      <text class="bubble-combo-label">已消除</text>
    </view>

    <!-- emoji 场 -->
    <view class="emoji-field">
      <block wx:for="{{emojiItems}}" wx:key="id">
        <view
          wx:if="{{!item.gone}}"
          class="emoji-item {{item.popping ? 'emoji-item--pop' : 'emoji-item--fall'}}"
          style="left:{{item.x}}rpx;top:{{item.finalY}}rpx;font-size:{{item.size}}rpx;animation-duration:{{item.dur}}s;animation-delay:{{item.delay}}s;"
          bindtap="tapEmoji"
          data-id="{{item.id}}"
        >{{item.emoji}}</view>
      </block>
    </view>

    <!-- 清空完成：页面中间提示 -->
    <view class="bubble-clear-done {{showClearDone ? 'bubble-clear-done--visible' : ''}}">
      <text class="bubble-clear-done__title">{{clearDoneText}}</text>
      <view class="bubble-clear-done__btn" bindtap="restartBubbleGame">
        <text class="bubble-clear-done__btn-text">再来一次</text>
      </view>
    </view>
  </view>

  <!-- 游戏三：涂鸦 -->
  <view class="doodle-game" wx:if="{{currentGame === 'doodle'}}">
    <!-- 画布 -->
    <view class="doodle-canvas-wrap">
      <canvas
        type="2d"
        id="doodleCanvas"
        class="doodle-canvas"
        style="width:100%;height:{{doodleCanvasH}}px;"
        bindtouchstart="doodleStart"
        bindtouchmove="doodleMove"
        bindtouchend="doodleEnd"
      ></canvas>
      <!-- 清空按钮：画布有内容时显示在中央 -->
      <view
        wx:if="{{doodleHasContent}}"
        class="doodle-clear-overlay"
        bindtap="clearDoodle"
      >
        <text class="doodle-clear-overlay__text">清空</text>
      </view>
    </view>

    <!-- 颜色工具栏 -->
    <view class="doodle-toolbar">
      <view class="color-picker">
        <block wx:for="{{doodleColors}}" wx:key="index">
          <view
            class="color-dot {{doodleColorIndex === index ? 'color-dot--active' : ''}}"
            style="background:{{item}};"
            bindtap="setDoodleColor"
            data-index="{{index}}"
          ></view>
        </block>
        <!-- 色相环自定义颜色 -->
        <view class="doodle-toolbar-divider"></view>
        <view class="doodle-color-wheel {{doodleColorIndex === -1 ? 'doodle-color-wheel--active' : ''}}" style="{{doodleCustomColor ? 'background:' + doodleCustomColor + ';' : ''}}">
          <picker
            mode="color"
            value="{{doodleCustomColor || '#E05252'}}"
            bindchange="onDoodleColorPickerChange"
          >
            <view class="doodle-color-wheel__inner">
              <text style="{{doodleColorIndex === -1 ? 'color:#fff;' : ''}}">+</text>
            </view>
          </picker>
        </view>
      </view>
    </view>
  </view>

  <!-- 完成页（背景内容） -->
  <view class="done-screen" wx:if="{{showDonePanel}}">
    <text class="done-emoji">🌿</text>
    <text class="done-title">感觉好一些了吗？</text>
    <text class="done-body">记得，情绪没有对错。</text>
  </view>

  <!-- 完成页底部面板 -->
  <view class="bottom-action {{showDonePanel ? 'bottom-action--visible' : ''}}">
    <!-- 右上角关闭按钮 -->
    <view class="done-panel-close" bindtap="closeDonePanel">✕</view>

    <!-- 居中完成内容 -->
    <view class="done-panel-hero">
      <text class="done-panel-emoji">🌿</text>
      <text class="done-panel-title">感觉好一些了吗？</text>
      <text class="done-panel-body">记得，情绪没有对错。</text>
    </view>

    <!-- 输入框 -->
    <view class="inline-input-wrap">
      <textarea
        class="inline-input"
        placeholder="{{inputPlaceholder}}"
        placeholder-class="inline-placeholder"
        value="{{journalText}}"
        bindinput="onJournalInput"
        auto-height
        maxlength="500"
        show-confirm-bar="{{false}}"
        adjust-position="{{true}}"
      ></textarea>
    </view>

    <!-- 按钮行 -->
    <view class="panel-btn-row">
      <button class="panel-btn panel-btn--secondary" bindtap="goBack">
        <text class="panel-btn__text panel-btn__text--secondary">回首页</text>
      </button>
      <button class="panel-btn panel-btn--primary {{journalText.length === 0 ? 'panel-btn--disabled' : ''}}" bindtap="saveJournal">
        <text class="panel-btn__text">写下来</text>
      </button>
    </view>
  </view>

</view>
