/* ===== Flomi 解压游戏页 ===== */

.page {
  width: 100%;
  min-height: 100vh;
  background: var(--color-background);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 背景 */
.ambient-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
.orb { position: absolute; border-radius: 9999rpx; filter: blur(160rpx); }
.orb--a { top: -200rpx; left: -100rpx; width: 600rpx; height: 600rpx; background: rgba(200, 180, 255, 0.25); }
.orb--b { bottom: -200rpx; right: -100rpx; width: 700rpx; height: 700rpx; background: rgba(218, 232, 190, 0.2); }


/* ===== 游戏选择菜单 ===== */
.game-selector {
  position: relative;
  z-index: 10;
  flex: 1;
  padding: 32rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.selector-title {
  font-size: 28rpx;
  color: var(--color-on-surface-variant);
  letter-spacing: 0.05em;
}

.game-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.game-card {
  background: var(--color-surface-container-low);
  border-radius: 40rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  border: 1rpx solid var(--color-outline-variant);
  transition: transform 0.2s;
}

.game-card:active { transform: scale(0.97); }

.game-card__icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.game-card__icon-wrap--breath { background: rgba(184, 192, 255, 0.5); }
.game-card__icon-wrap--bubble { background: rgba(218, 232, 190, 0.6); }
.game-card__icon-wrap--doodle { background: rgba(255, 218, 150, 0.5); }

.game-card__icon { font-size: 40rpx; color: var(--color-on-surface); }
.game-card__name { font-size: 34rpx; font-weight: 600; color: var(--color-on-surface); }
.game-card__desc { font-size: 26rpx; color: var(--color-on-surface-variant); line-height: 1.5; }
.game-card__duration { font-size: 22rpx; color: var(--color-outline); margin-top: 4rpx; }

/* ===== 呼吸游戏 ===== */
.breath-game {
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  padding: 0 48rpx calc(160rpx + env(safe-area-inset-bottom));
}

.breath-circle-wrap {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.breath-ring {
  position: absolute;
  border-radius: 9999rpx;
  transition: transform 1s ease-in-out, opacity 1s ease-in-out;
}

.breath-ring--outer {
  width: 400rpx;
  height: 400rpx;
  background: rgba(184, 192, 255, 0.15);
}

.breath-ring--mid {
  width: 340rpx;
  height: 340rpx;
  background: rgba(184, 192, 255, 0.2);
}

.breath-circle {
  width: 280rpx;
  height: 280rpx;
  border-radius: 9999rpx;
  background: rgba(184, 192, 255, 0.55);
  border: 2rpx solid rgba(83, 91, 147, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  transition: transform 1s ease-in-out, background 0.5s;
  box-shadow: 0 16rpx 64rpx rgba(83, 91, 147, 0.2);
  z-index: 1;
}

/* 吸气：放大 */
.inhale .breath-circle { transform: scale(1.35); background: rgba(184, 192, 255, 0.7); }
.inhale .breath-ring--mid { transform: scale(1.2); opacity: 0.8; }
.inhale .breath-ring--outer { transform: scale(1.15); opacity: 0.6; }

/* 屏气：保持 */
.hold .breath-circle { transform: scale(1.35); background: rgba(218, 232, 190, 0.7); }
.hold .breath-ring--mid { transform: scale(1.2); opacity: 0.6; }

/* 呼气：缩小 */
.exhale .breath-circle { transform: scale(1.0); background: rgba(184, 192, 255, 0.4); }
.exhale .breath-ring--mid { transform: scale(1.0); opacity: 0.4; }
.exhale .breath-ring--outer { transform: scale(1.0); opacity: 0.3; }

.breath-count {
  font-size: 80rpx;
  font-weight: 300;
  color: var(--color-on-surface);
  letter-spacing: -0.04em;
  line-height: 1;
}

.breath-count-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--color-on-surface-variant);
  letter-spacing: 0.08em;
  opacity: 0.6;
  line-height: 1;
}

.breath-instruction {
  font-size: 40rpx;
  font-weight: 500;
  color: var(--color-on-surface);
  letter-spacing: 0.05em;
}

.breath-round {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
}

.breath-progress {
  width: 100%;
  height: 6rpx;
  background: var(--color-surface-container);
  border-radius: 9999rpx;
  overflow: hidden;
}

.breath-progress__bar {
  height: 100%;
  border-radius: 9999rpx;
  transition: width 1s linear, background 0.5s;
}

/* ===== 捏气泡游戏 ===== */
.bubble-game {
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
}


.bubble-game__field {
  flex: 1;
  position: relative;
}

.game-bubble {
  position: absolute;
  border-radius: 9999rpx;
  border: 1rpx solid rgba(255,255,255,0.4);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06), inset 0 2rpx 8rpx rgba(255,255,255,0.5);
  animation: gameBubbleFloat ease-in-out infinite alternate;
  transition: transform 0.1s;
}

.game-bubble:active { transform: scale(0.88) !important; }

.game-bubble__shimmer {
  position: absolute;
  inset: 0;
  border-radius: 9999rpx;
  background: radial-gradient(ellipse at 28% 22%, rgba(255,255,255,0.55) 0%, transparent 55%);
}

.game-bubble--pop {
  animation: gameBubblePop 0.3s ease-out forwards !important;
}

.game-bubble--gone { display: none; }

@keyframes gameBubbleFloat {
  0%   { transform: translateY(0); }
  100% { transform: translateY(-24rpx); }
}

@keyframes gameBubblePop {
  0%   { transform: scale(1);    opacity: 1; }
  40%  { transform: scale(1.3);  opacity: 0.7; }
  100% { transform: scale(0);    opacity: 0; }
}

/* ===== 涂鸦游戏 ===== */
.doodle-game {
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.doodle-canvas {
  flex: 1;
  width: 100%;
  background: rgba(245, 244, 239, 0.8);
}

.doodle-toolbar {
  padding: 24rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background: rgba(251, 249, 245, 0.9);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid var(--color-outline-variant);
}

.color-picker {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  align-items: center;
  flex-wrap: wrap;
}

.color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 9999rpx;
  border: 3rpx solid transparent;
  transition: transform 0.2s;
}

.color-dot--active {
  border-color: var(--color-on-surface);
  transform: scale(1.2);
}

.doodle-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  align-items: center;
  justify-content: flex-end;
}

.doodle-clear-btn {
  padding: 16rpx 32rpx;
  background: var(--color-surface-container);
  border-radius: 9999rpx;
}

.doodle-clear-btn__text {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
}

/* 底部固定结束按钮栏 */
.bottom-stop-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 20rpx 40rpx calc(env(safe-area-inset-bottom) + 20rpx);
}

.stop-btn {
  width: 100%;
  padding: 28rpx 0;
  background: rgba(49, 51, 47, 0.75);
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.stop-btn:active { transform: scale(0.97); }
.stop-btn--inline { margin: 0; padding: 16rpx 32rpx; background: rgba(49, 51, 47, 0.75); }
.stop-btn__text { font-size: 30rpx; font-weight: 500; color: #fff; }

/* 完成页底部面板（复用首页样式） */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 120;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 36rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  background: rgba(251, 249, 245, 0.92);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 40rpx 40rpx 0 0;
  box-shadow: 0 -8rpx 48rpx rgba(0, 0, 0, 0.08);
  transform: translateY(100%);
  transition: transform 0.48s cubic-bezier(0.22, 1, 0.36, 1);
  pointer-events: none;
}

.bottom-action--visible {
  transform: translateY(0);
  pointer-events: auto;
}

.inline-input-wrap {
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: column;
}

.inline-input {
  width: 100%;
  font-size: 28rpx;
  color: var(--color-on-surface);
  line-height: 1.7;
  font-weight: 300;
  background: transparent;
  min-height: 160rpx;
  max-height: 320rpx;
}

.inline-placeholder {
  color: var(--color-outline-variant);
  font-style: italic;
  font-weight: 300;
}

/* 面板标题行 */
.inline-panel-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 4rpx;
}

.inline-panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-on-surface);
  letter-spacing: -0.01em;
}

/* 双按钮行 */
.panel-btn-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.panel-btn {
  flex: 1;
  padding: 28rpx 0;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s, opacity 0.2s;
}

.panel-btn:active { transform: scale(0.97); }

.panel-btn--primary { background: rgba(87, 99, 66, 0.55); }
.panel-btn--secondary { background: rgba(49, 51, 47, 0.08); }

.panel-btn--disabled {
  opacity: 0.3;
  pointer-events: none;
}

.panel-btn__text {
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
  letter-spacing: 0.02em;
}

.panel-btn__text--secondary {
  color: var(--color-on-surface-variant);
}

/* ===== 完成页 ===== */
.done-screen {
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 0 64rpx;
}

.done-emoji { font-size: 120rpx; }
.done-title { font-size: 52rpx; font-weight: 600; color: var(--color-on-surface); letter-spacing: -0.02em; }
.done-body { font-size: 28rpx; color: var(--color-on-surface-variant); text-align: center; line-height: 1.6; }

.done-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  margin-top: 32rpx;
}

.done-btn {
  width: 100%;
  padding: 36rpx 0;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.done-btn:active { transform: scale(0.97); }
.done-btn--primary { background: var(--color-primary); }
.done-btn--ghost { background: var(--color-surface-container); }
.done-btn__text { font-size: 32rpx; font-weight: 600; color: #fff; }
.done-btn__text--ghost { color: var(--color-on-surface-variant); }
