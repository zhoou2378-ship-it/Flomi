/* ===== Flomi 解压游戏页 ===== */

.page {
  width: 100%;
  min-height: 100vh;
  background: var(--color-background);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 导航栏容器（与胶囊同行） */
.game-nav-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 200;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 24rpx;
}

/* 返回按钮（圆形） */
.game-back-btn {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  display: flex;
  align-items: center;
  justify-content: center;
}

.game-back-icon {
  font-size: 52rpx;
  color: var(--color-on-surface);
  line-height: 1;
  margin-left: -4rpx;
  font-weight: 300;
}

/* 页面标题（绝对居中，不受返回按钮影响） */
.game-nav-title {
  position: absolute;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-on-surface);
  letter-spacing: -0.01em;
  pointer-events: none;
}

/* 背景 */
.ambient-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
.orb { position: absolute; border-radius: 9999rpx; filter: blur(160rpx); }
.orb--a { top: -200rpx; left: -100rpx; width: 600rpx; height: 600rpx; background: rgba(200, 180, 255, 0.25); }
.orb--b { bottom: -200rpx; right: -100rpx; width: 700rpx; height: 700rpx; background: rgba(218, 232, 190, 0.2); }


/* ===== 游戏选择菜单 ===== */
.game-selector {
  position: relative;
  z-index: 10;
  flex: 1;
  padding: 32rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.selector-title {
  font-size: 28rpx;
  color: var(--color-on-surface-variant);
  letter-spacing: 0.05em;
}

.game-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.game-card {
  background: var(--color-surface-container-low);
  border-radius: 40rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  border: 1rpx solid var(--color-outline-variant);
  transition: transform 0.2s;
}

.game-card:active { transform: scale(0.97); }

.game-card__icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.game-card__icon-wrap--breath { background: rgba(184, 192, 255, 0.5); }
.game-card__icon-wrap--bubble { background: rgba(218, 232, 190, 0.6); }
.game-card__icon-wrap--doodle { background: rgba(255, 218, 150, 0.5); }

.game-card__icon { font-size: 40rpx; color: var(--color-on-surface); }
.game-card__name { font-size: 34rpx; font-weight: 600; color: var(--color-on-surface); }
.game-card__desc { font-size: 26rpx; color: var(--color-on-surface-variant); line-height: 1.5; }
.game-card__duration { font-size: 22rpx; color: var(--color-outline); margin-top: 4rpx; }

/* ===== 呼吸游戏 ===== */
.breath-game {
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 60rpx;
  padding: 0 48rpx 60rpx;
}

.breath-circle-wrap {
  position: relative;
  width: 560rpx;
  height: 560rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -40rpx;
}

.breath-ring {
  position: absolute;
  border-radius: 9999rpx;
  transition: transform 1s ease-in-out, opacity 1s ease-in-out;
}

.breath-ring--outer {
  width: 560rpx;
  height: 560rpx;
  background: rgba(184, 192, 255, 0.12);
  border: none;
  animation: breathRingPulse 4s ease-in-out infinite;
}

.breath-ring--mid {
  width: 470rpx;
  height: 470rpx;
  background: rgba(184, 192, 255, 0.18);
  border: none;
  animation: breathRingPulse 4s ease-in-out infinite 0.6s;
}

@keyframes breathRingPulse {
  0%   { transform: scale(1);    opacity: 0.7; }
  50%  { transform: scale(1.06); opacity: 1; }
  100% { transform: scale(1);    opacity: 0.7; }
}

.breath-circle {
  width: 380rpx;
  height: 380rpx;
  border-radius: 9999rpx;
  background: rgba(184, 192, 255, 0.55);
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  transition: transform 1s ease-in-out, background 0.5s;
  box-shadow: 0 16rpx 64rpx rgba(83, 91, 147, 0.2);
  z-index: 1;
}

/* 吸气 */
.inhale .breath-circle { transform: scale(1.35); background: rgba(184, 192, 255, 0.7); }
.inhale .breath-ring--mid { transform: scale(1.2); opacity: 0.8; }
.inhale .breath-ring--outer { transform: scale(1.15); opacity: 0.6; }

/* 屏气 */
.hold .breath-circle { transform: scale(1.35); background: rgba(218, 232, 190, 0.7); }
.hold .breath-ring--mid { transform: scale(1.2); opacity: 0.6; }

/* 呼气 */
.exhale .breath-circle { transform: scale(1.0); background: rgba(184, 192, 255, 0.4); }
.exhale .breath-ring--mid { transform: scale(1.0); opacity: 0.4; }
.exhale .breath-ring--outer { transform: scale(1.0); opacity: 0.3; }

/* 圆圈内：开始文字 */
.breath-start-text {
  font-size: 56rpx;
  font-weight: 200;
  color: var(--color-on-surface);
  letter-spacing: 0.08em;
}

/* 圆圈内：动作标签（吸气/屏气/呼气） */
.breath-action {
  font-size: 34rpx;
  font-weight: 400;
  color: var(--color-on-surface);
  letter-spacing: 0.06em;
  line-height: 1;
}

/* 圆圈内：秒数 */
.breath-count {
  font-size: 56rpx;
  font-weight: 200;
  color: rgba(120, 110, 180, 0.85);
  letter-spacing: -0.02em;
  line-height: 1;
}

.breath-count-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: rgba(120, 110, 180, 0.55);
  letter-spacing: 0.08em;
  line-height: 1;
}

.breath-round {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  margin-bottom: -20rpx;
}

.breath-round--hidden {
  visibility: hidden;
}

/* 进度条：最大宽度 68% */
.breath-progress-wrap {
  width: 68%;
}

.breath-progress-wrap--hidden {
  visibility: hidden;
}

.breath-progress {
  width: 100%;
  height: 6rpx;
  background: var(--color-surface-container);
  border-radius: 9999rpx;
  overflow: hidden;
}

.breath-progress__bar {
  height: 100%;
  border-radius: 9999rpx;
  transition: width 1s linear, background 0.5s;
}

/* 控制按钮组 */
.breath-controls {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  align-items: center;
  justify-content: center;
  margin-top: 8rpx;
}

.breath-ctrl-btn {
  padding: 24rpx 68rpx;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.18s, opacity 0.18s;
}

.breath-ctrl-btn:active { transform: scale(0.95); }

.breath-ctrl-btn--primary {
  background: rgba(49, 51, 47, 0.08);
}


.breath-ctrl-btn--secondary {
  background: rgba(140, 148, 200, 0.25);
}

.breath-ctrl-btn--ghost {
  background: rgba(49, 51, 47, 0.07);
}

.breath-ctrl-text {
  font-size: 30rpx;
  font-weight: 500;
  color: rgba(49, 51, 47, 0.65);
  letter-spacing: 0.04em;
}

.breath-ctrl-text--secondary {
  color: rgba(83, 91, 147, 0.9);
}

.breath-ctrl-text--ghost {
  color: rgba(49, 51, 47, 0.45);
}

/* ===== 烦恼消消 ===== */
.emoji-game {
  position: relative;
  z-index: 10;
  flex: 1;
  overflow: hidden;
}

.emoji-back-btn {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 16rpx);
  right: 32rpx;
  z-index: 200;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.emoji-back-icon {
  font-size: 52rpx;
  color: rgba(49, 51, 47, 0.45);
  line-height: 1;
}

.emoji-field {
  position: absolute;
  inset: 0;
  padding-bottom: max(calc(env(safe-area-inset-bottom) + 20rpx), 60rpx);
  overflow: hidden;
  box-sizing: border-box;
}

.emoji-item {
  position: absolute;
  /* top 由 JS 设为 finalY，初始通过 translateY 从屏幕顶部外开始掉落 */
  line-height: 1;
  user-select: none;
  cursor: pointer;
  transform-origin: center bottom;
  animation-name: emojiFall;
  /* 线性落下，无回弹 */
  animation-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  animation-fill-mode: both;
  animation-iteration-count: 1;
}

.emoji-item:active {
  transform: scale(0.75) !important;
}

/* 从屏幕顶部外（-120vh）线性落下到位，无回弹 */
@keyframes emojiFall {
  0%   {
    transform: translateY(-120vh) scale(0.7) rotate(-6deg);
    opacity: 0;
  }
  40%  {
    opacity: 1;
  }
  100% {
    transform: translateY(0) scale(1) rotate(0deg);
    opacity: 1;
  }
}

.emoji-item--pop {
  opacity: 0 !important;
  pointer-events: none;
}

.clear-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.85);
  z-index: 300;
  background: rgba(49, 51, 47, 0.82);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 32rpx 48rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.clear-toast--visible {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.clear-toast__text {
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
  letter-spacing: 0.02em;
  white-space: nowrap;
}

/* ===== 清空烦恼 combo 计数 ===== */
.bubble-combo-bar {
  position: absolute;
  top: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 8rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 9999rpx;
  padding: 10rpx 28rpx;
  pointer-events: none;
  white-space: nowrap;
}

.bubble-combo-num {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(49, 51, 47, 0.65);
  letter-spacing: -0.01em;
  line-height: 1;
}

.bubble-combo-label {
  font-size: 22rpx;
  font-weight: 400;
  color: rgba(49, 51, 47, 0.45);
  letter-spacing: 0.02em;
}

.bubble-combo-num--done {
  font-size: 28rpx;
  color: rgba(49, 51, 47, 0.65);
}

.bubble-combo-label--done {
  font-size: 22rpx;
  color: rgba(49, 51, 47, 0.45);
  letter-spacing: 0.02em;
}

/* ===== 涂鸦游戏 ===== */
.doodle-game {
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.doodle-canvas {
  flex: 1;
  width: 100%;
  background: rgba(245, 244, 239, 0.8);
}

.doodle-toolbar {
  padding: 24rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background: rgba(251, 249, 245, 0.9);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid var(--color-outline-variant);
}

.color-picker {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  align-items: center;
  flex-wrap: wrap;
}

.color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 9999rpx;
  border: 3rpx solid transparent;
  transition: transform 0.2s;
}

.color-dot--active {
  border-color: var(--color-on-surface);
  transform: scale(1.2);
}

.doodle-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  align-items: center;
  justify-content: flex-end;
}

.doodle-clear-btn {
  padding: 16rpx 32rpx;
  background: var(--color-surface-container);
  border-radius: 9999rpx;
}

.doodle-clear-btn__text {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
}

.stop-btn {
  width: 100%;
  padding: 28rpx 0;
  background: rgba(49, 51, 47, 0.75);
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.stop-btn:active { transform: scale(0.97); }
.stop-btn--inline { margin: 0; padding: 16rpx 32rpx; width: auto; background: rgba(49, 51, 47, 0.75); }
.stop-btn__text { font-size: 30rpx; font-weight: 500; color: #fff; }

/* ===== 完成页背景内容（被面板遮住，仅占位） ===== */
.done-screen {
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 0 64rpx;
}

/* ===== 完成页底部面板 ===== */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 64vh;
  z-index: 120;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding: 36rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  box-sizing: border-box;
  background: rgba(251, 249, 245, 0.92);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 40rpx 40rpx 0 0;
  box-shadow: 0 -8rpx 48rpx rgba(0, 0, 0, 0.08);
  transform: translateY(100%);
  transition: transform 0.48s cubic-bezier(0.22, 1, 0.36, 1);
  pointer-events: none;
}

.bottom-action--visible {
  transform: translateY(0);
  pointer-events: auto;
}

/* 右上角关闭按钮 */
.done-panel-close {
  position: absolute;
  top: 28rpx;
  right: 32rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: rgba(49, 51, 47, 0.65);
  line-height: 1;
  transition: color 0.15s;
}

.done-panel-close:active {
  color: rgba(49, 51, 47, 0.9);
}

/* 面板内居中完成内容 */
.done-panel-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 32rpx 0 32rpx;
}

.done-panel-emoji {
  font-size: 80rpx;
  line-height: 1;
}

.done-panel-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-on-surface);
  letter-spacing: -0.02em;
  text-align: center;
}

.done-panel-body {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  text-align: center;
  line-height: 1.6;
}

/* 输入框 */
.inline-input-wrap {
  flex: 1;
  min-height: 0;
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: column;
}

.inline-input {
  flex: 1;
  width: 100%;
  font-size: 28rpx;
  color: var(--color-on-surface);
  line-height: 1.7;
  font-weight: 300;
  background: transparent;
}

.inline-placeholder {
  color: var(--color-outline-variant);
  font-style: italic;
  font-weight: 300;
}

/* 双按钮行 */
.panel-btn-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.panel-btn {
  flex: 1;
  padding: 28rpx 0;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s, opacity 0.2s;
}

.panel-btn:active { transform: scale(0.97); }

.panel-btn--primary { background: rgba(87, 99, 66, 0.55); }
.panel-btn--secondary { background: rgba(49, 51, 47, 0.08); }

.panel-btn--disabled {
  opacity: 0.3;
  pointer-events: none;
}

.panel-btn__text {
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
  letter-spacing: 0.02em;
}

.panel-btn__text--secondary {
  color: var(--color-on-surface-variant);
}
